# ─────────────────────────────────────────────────────────────────────────────
# Trave — RTX 3090 (24 GB VRAM) configuration
#
# VRAM budget (all models loaded simultaneously):
#   Qwen3.5 9B Q8_0       ~10 GB
#   Chatterbox Turbo 350M  ~2 GB
#   WhisperX large-v3      ~3 GB  (+alignment ~1 GB, +diarization ~1 GB)
#   Total                  ~17 GB  (fits comfortably in 24 GB)
# ─────────────────────────────────────────────────────────────────────────────

# ── Gateway ──────────────────────────────────────────────────────────────────
GATEWAY_PORT=3000

# ── LLM (llama.cpp) ─────────────────────────────────────────────────────────
# Qwen3.5 9B — strong reasoning model, fits fully in 24 GB at Q8_0
LLAMA_HF_REPO=unsloth/Qwen3.5-9B-GGUF:Q8_0
LLAMA_CTX_SIZE=8192
LLAMA_N_GPU_LAYERS=99
# Unload from memory after 10 minutes of inactivity
LLAMA_IDLE_TIMEOUT=600

# ── TTS (Chatterbox) ────────────────────────────────────────────────────────
# Turbo: 350M params, lowest latency, paralinguistic tags ([laugh], [cough])
CHATTERBOX_DEFAULT_MODEL=chatterbox-turbo
# Unload after 5 minutes idle
CHATTERBOX_IDLE_TIMEOUT=300

# ── STT (WhisperX) ──────────────────────────────────────────────────────────
# large-v3: best accuracy, <3 GB VRAM with float16, 70x realtime
WHISPERX_DEFAULT_MODEL=large-v3
WHISPERX_COMPUTE_TYPE=float16
WHISPERX_BATCH_SIZE=16
# Enable diarization pipeline (loaded lazily on first diarize request)
WHISPERX_ENABLE_DIARIZATION=true
# Unload after 5 minutes idle
WHISPERX_IDLE_TIMEOUT=300

# ── Shared ───────────────────────────────────────────────────────────────────
# HuggingFace token — required for diarization (pyannote) and gated models
# Generate at https://huggingface.co/settings/tokens
# Accept pyannote terms at https://huggingface.co/pyannote/speaker-diarization-community-1
HF_TOKEN=
